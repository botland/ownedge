# === Appliance Identity ===
APPLIANCE_ID=inferedge-dev-001
COMPOSE_PROJECT_NAME=inferedge

# === Hardware Profile ===
GPU_PROFILE=auto
DEFAULT_MODEL=meta-llama/Llama-3.1-8B-Instruct
DEFAULT_CONTEXT=8192
GPU_UTILIZATION=0.85

# === Credentials ===
MINIO_ROOT_USER=inferedge
MINIO_ROOT_PASSWORD=change-me-in-production
CONTROLLER_API_TOKEN=change-me-in-production

# === Controller ===
CONTROLLER_PORT=8080
SQLITE_DB_PATH=/data/inferedge.db
# Host path bind-mounted to /models_cache inside containers (do not use host path as LOCAL_MODEL_CACHE)
MODEL_CACHE_HOST=/var/lib/inferedge/models

# === Ray (single-node for Phase 1) ===
RAY_HEAD_PORT=10001
RAY_DASHBOARD_PORT=8265

# === vLLM (managed by Controller) ===
VLLM_INTERNAL_PORT=8000
VLLM_IMAGE=vllm/vllm-openai:latest
VLLM_CONTAINER_STARTUP_TIMEOUT_SEC=120
VLLM_PROBE_TIMEOUT_SEC=600

# === Reconciler ===
RECONCILE_INTERVAL_SEC=5
HF_DOWNLOAD_TIMEOUT_SEC=7200
HF_DOWNLOAD_STALL_SEC=1200
MIN_FREE_DISK_GB=20

# === HF Token (required for gated models e.g. meta-llama/*) ===
# Create at https://huggingface.co/settings/tokens and accept model license on the model page.
HF_TOKEN=